---
source: crates/mnemonist-core/src/config.rs
expression: toml_str
---
[storage]
root = "~/.mnemonist"

[embedding]
provider = "candle"
model = "all-MiniLM-L6-v2"

[recall]
budget = 2000
priority = [
    "feedback",
    "project",
    "user",
    "reference",
]
expand_refs = true
max_ref_expansions = 3
min_similarity = 0.3499999940395355
min_results = 2

[index]
max_lines = 200

[code]
languages = [
    "rust",
    "python",
    "javascript",
    "go",
]
max_chunk_lines = 100
exclude_patterns = [
    "dist",
    "build",
    "out",
    "_build",
    "node_modules",
    "vendor",
    ".venv",
    "venv",
    "target",
    "__pycache__",
    ".next",
    ".nuxt",
    ".turbo",
    "package-lock",
    "yarn.lock",
    "pnpm-lock",
    "cargo.lock",
    "poetry.lock",
    ".min.js",
    ".min.css",
    ".map",
    ".chunk.",
    ".bundle.",
]

[quantization]
enabled = false
bits = 2
algorithm = "mse"
temporal_weight = 0.20000000298023224

[consolidation]
decay_days = 90
merge_threshold = 0.8500000238418579
protected_access_count = 5
max_memories = 200
max_memory_tokens = 120

[inbox]
capacity = 7

[output]
quiet = false
