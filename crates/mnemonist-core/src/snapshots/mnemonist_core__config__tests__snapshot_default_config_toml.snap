---
source: crates/mnemonist-core/src/config.rs
expression: toml_str
---
[storage]
root = "~/.mnemonist"

[embedding]
provider = "candle"
model = "sentence-transformers/all-MiniLM-L6-v2"

[recall]
budget = 2000
expand_refs = true
max_ref_expansions = 3
min_results = 2

[index]
max_lines = 200

[code]
exclude_patterns = [
    "dist",
    "build",
    "out",
    "_build",
    "node_modules",
    "vendor",
    ".venv",
    "venv",
    "target",
    "__pycache__",
    ".next",
    ".nuxt",
    ".turbo",
    "package-lock",
    "yarn.lock",
    "pnpm-lock",
    "cargo.lock",
    "poetry.lock",
    ".min.js",
    ".min.css",
    ".map",
    ".chunk.",
    ".bundle.",
]

[consolidation]
decay_days = 90
merge_threshold = 0.8500000238418579
protected_access_count = 5
max_memory_tokens = 120
auto = true
auto_stale_days = 7

[inbox]
capacity = 10

[output]
quiet = false
